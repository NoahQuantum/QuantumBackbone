import numpy as np

from typing import List, Dict, Tuple, Set





class FinancialPoset:

    """

    Represents an option chain or asset class framework as a Partially Ordered Set (Poset).

    In traditional finance, risk is a flat matrix. Here, risk is a directed acyclic 

    graph (DAG) representing systemic vulnerability and cascading failure pathways.

    

    Order Relations (a <= b):

    - For Options: Defined by dominance in Strike (K), Expiry (T), and Implied Volatility (IV).

    - An option 'a' is lower than 'b' if its failure/collapse guarantees the collapse of 'b'.

    """

    def __init__(self, elements: List[str]):

        self.elements: List[str] = elements

        # Adjacency matrix to represent the partial order relation

        self.size = len(elements)

        self.relations: np.ndarray = np.zeros((self.size, self.size), dtype=bool)

        

    def _get_index(self, item: str) -> int:

        if item not in self.elements:

            raise ValueError(f"Element {item} not found in Poset spectrum.")

        return self.elements.index(item)



    def add_relation(self, lower_item: str, greater_item: str):

        """

        Defines the partial order relation: lower_item <= greater_item.

        In financial terms, 'lower_item' is the foundational risk trigger for 'greater_item'.

        """

        idx_lower = self._get_index(lower_item)

        idx_greater = self._get_index(greater_item)

        self.relations[idx_lower][idx_greater] = True

        

        # Enforce Reflexivity: a <= a

        for i in range(self.size):

            self.relations[i][i] = True

            

        # Apply Transitive Closure (If a<=b and b<=c, then a<=c)

        self._apply_transitive_closure()



    def _apply_transitive_closure(self):

        """

        Applies Floyd-Warshall algorithm to ensure transitivity in the financial topology.

        This models the cascading effect of market shocks through systemic layers.

        """

        for k in range(self.size):

            for i in range(self.size):

                for j in range(self.size):

                    if self.relations[i][k] and self.relations[k][j]:

                        self.relations[i][j] = True



    def get_chains(self) -> List[List[str]]:

        """

        Extracts all totally ordered subsets (Chains) from the Poset.

        These chains represent sequential paths of risk contagion or nested option hedges.

        """

        chains = []

        def backtrack(curr_idx: int, current_chain: List[int]):

            chains.append([self.elements[i] for i in current_chain])

            for next_idx in range(self.size):

                if next_idx != curr_idx and self.relations[curr_idx][next_idx]:

                    # Ensure it extends sequentially without violating anti-symmetry

                    if next_idx not in current_chain:

                        backtrack(next_idx, current_chain + [next_idx])



        for start_idx in range(self.size):

            backtrack(start_idx, [start_idx])

            

        # Filter out sub-chains to keep maximal structural pathways

        max_chains = []

        for c in sorted(chains, key=len, reverse=True):

            if not any(set(c).issubset(set(m)) for m in max_chains if c != m):

                max_chains.append(c)

        return max_chains





class SimplicialAllocator:

    """

    Transforms asset weights into a geometrical Simplex coordinate system.

    Because asset allocations must sum to 1.0 (Sum(w_i) = 1), the portfolio space

    is inherently an (N-1)-dimensional Simplex rather than Euclidean space.

    

    This class tracks how Black Swan perturbations distort the manifold.

    """

    def __init__(self, asset_tickers: List[str]):

        self.tickers = asset_tickers

        self.dim = len(asset_tickers)



    def project_to_simplex(self, raw_weights: np.ndarray) -> np.ndarray:

        """

        Projects arbitrary real-valued market signals onto the valid canonical Simplex.

        Uses a high-performance sorting projection algorithm to guarantee sum=1 and w_i >= 0.

        Essential for transforming unconstrained raw quantum/stochastic outputs into actionable orders.

        """

        sorted_weights = np.sort(raw_weights)[::-1]

        cumulative_sums = np.cumsum(sorted_weights)

        

        tmp = (cumulative_sums - 1.0) / np.arange(1, self.dim + 1)

        conditions = sorted_weights > tmp

        rho = np.max(np.where(conditions)[0]) + 1

        

        theta = (cumulative_sums[rho - 1] - 1.0) / rho

        projected_weights = np.maximum(raw_weights - theta, 0.0)

        return projected_weights



    def calculate_simplex_volume_distortion(self, volatility_vector: np.ndarray) -> float:

        """

        Measures the geometric distortion of the portfolio simplex under shock conditions.

        Acts as an anti-fragile gauge. If market volatility warps the barycentric volume 

        beyond critical thresholds, it triggers defensive rebalancing via IBKR API.

        

        Formula derived from the Cayley-Menger determinant for financial geometry.

        """

        assert len(volatility_vector) == self.dim, "Volatility dimension mismatch."

        

        # Construct the distance matrix based on asset volatility profile

        # This models the geometric 'distance' stretching between assets during stress

        dist_matrix = np.zeros((self.dim + 1, self.dim + 1))

        for i in range(self.dim):

            for j in range(self.dim):

                dist_matrix[i][j] = (volatility_vector[i] - volatility_vector[j]) ** 2

                

        # Fill borders for the Cayley-Menger determinant structure

        dist_matrix[:, self.dim] = 1.0

        dist_matrix[self.dim, :] = 1.0

        dist_matrix[self.dim][self.dim] = 0.0

        

        # Calculate determinant to find the generalized non-Euclidean volume

        det = np.linalg.det(dist_matrix)

        

        # Generalized Simplex Volume calculation

        prefactor = ((-1) ** (self.dim)) / ((2 ** (self.dim - 1)) * (np.math.factorial(self.dim - 1) ** 2))

        volume_squared = prefactor * det

        

        return float(np.sqrt(np.abs(volume_squared)))





